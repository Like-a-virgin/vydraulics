{% set socials = seomatic.site.sameAsLinks %}

<ul class="flex flex-row gap-0.5 items-center">
    {% for item in socials %}
        {% if item.url %}
            {% if item.handle is same as 'youtube' %}
                <a href="{{ item.url }}" target="_blank" aria-label="{{ 'Ga naar'|t ~ ' ' ~ item.siteName }}" class="w-2 h-2 rounded-full border border-prim center hover:bg-prim group">{{ svg('assets/icons/' ~ item.handle ~ '.svg')|attr({class:"text-prim fill-prim w-1.25 h-auto text-black fill-black group-hover:text-white group-hover:fill-white"})}}</a>
            {% else %}
                <a href="{{ item.url }}" target="_blank" aria-label="{{ 'Ga naar'|t ~ ' ' ~ item.siteName }}" class="w-2 h-2 rounded-full border border-prim center hover:bg-prim group">{{ svg('assets/icons/' ~ item.handle ~ '.svg')|attr({class:"text-prim fill-prim w-auto h-0.75 text-black fill-black group-hover:text-white group-hover:fill-white"})}}</a>
            {% endif %}
        {% endif %}
    {% endfor %}
</ul>